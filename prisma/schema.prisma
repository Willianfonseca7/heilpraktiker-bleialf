generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TestTable {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}
model Patient {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPERADMIN
  ADMIN
}
