generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String   @unique
  passwordHash     String
  role             Role     @default(USER)
  isActive         Boolean  @default(true)
  sessionExpiresAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

}

model TestTable {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}
model Patient {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?
  createdAt DateTime @default(now())
}
